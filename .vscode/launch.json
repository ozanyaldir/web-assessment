{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Express Debug",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
              "run",
              "start",
            ],
            "cwd": "${workspaceRoot}/backend",
            "stopOnEntry": true,
            "autoAttachChildProcesses": true,
            "restart": true,
            "sourceMaps": true,
            "internalConsoleOptions": "openOnSessionStart",
            "console": "internalConsole",
            "outputCapture": "std",
            "env": {
            }
        }
    ]
}